@model JokesWebApp.Models.Joke

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Joke</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.JokeQuestion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.JokeQuestion)
            <button class="btn btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#answer">
                Show Answer
            </button>
            <div class="collapse mt-2" id="answer">
                <div class="card card-body">
                    @Html.DisplayFor(model => model.JokeAnswer)
                </div>
            </div>
        </dd>
        <dt class = "col-sm-2">
            @* @Html.DisplayNameFor(model => model.JokeAnswer) *@
        </dt>
        <dd class = "col-sm-10">
            @* @Html.DisplayFor(model => model.JokeAnswer) *@
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

<div class="mt-4">
    <button onclick="sendLaugh()" class="btn btn-outline-warning btn-lg">😂 That's Funny!</button>
</div>

<div id="emoji-container" style="position: relative;"></div>

<script>
    function sendLaugh() {
        const container = document.getElementById('emoji-container');
        const emoji = document.createElement('div');
        emoji.innerText = "😂";
        emoji.className = 'floating-emoji';
    
        // Randomize horizontal position slightly
        emoji.style.left = Math.random() * 50 + 'px';
    
        container.appendChild(emoji);
    
        // Clean up memory
        setTimeout(() => { emoji.remove(); }, 2000);
    }
</script>
