@model IEnumerable<JokesWebApp.Models.Joke>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 joke-card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-primary">Q: @Html.DisplayFor(modelItem => item.JokeQuestion)</h5>
                    <p class="card-text text-muted small">Click details to see the punchline!</p>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View Joke</a>
                </div>
            </div>
        </div>
    }
</div>
